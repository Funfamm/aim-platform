{
  "name": "aim-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma migrate deploy && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "prisma generate",
    "db:migrate": "node scripts/prisma-guard.mjs migrate dev && prisma migrate dev",
    "db:migrate:name": "node scripts/prisma-guard.mjs migrate dev && prisma migrate dev --name",
    "db:push": "node scripts/prisma-guard.mjs db push && prisma db push",
    "db:reset": "node scripts/prisma-guard.mjs migrate reset && prisma migrate reset",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:status": "prisma migrate status",
    "db:seed": "node scripts/prisma-guard.mjs db seed && tsx prisma/seed-superadmin.ts",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed-superadmin.ts"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.40.0",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@google/generative-ai": "^0.24.1",
    "@huggingface/transformers": "^3.8.1",
    "@prisma/client": "^6.19.2",
    "@sentry/nextjs": "^9.9.0",
    "@swc/helpers": "^0.5.19",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "eslint-config-next": "^16.2.1",
    "framer-motion": "^12.38.0",
    "glob": "^10.3.10",
    "jose": "^6.2.2",
    "next": "^15.2.4",
    "next-intl": "^4.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.1.0",
    "jest": "^30.3.0",
    "prisma": "^6.6.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.8.0",
    "vitest": "^4.1.1"
  }
}
