{
  "name": "aim-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node -e \"process.env.DATABASE_URL && (async () => { try { require('child_process').execSync('npx prisma migrate deploy', {stdio:'inherit'}); } catch (e) { console.log('Migration warning: Migrate deploy failed but continuing build. Ensure DB is synced manually.'); process.exit(0); } })()\"",
    "build": "next build",
    "build:prod": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=300",
    "lint:ci": "eslint . --max-warnings=240",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.config.ts 'integration.test'",
    "test:e2e": "playwright test",
    "test:axe": "playwright test tests/e2e/accessibility.spec.ts",
    "test:all": "npm run lint:ci && npx tsc --noEmit && npm test && npm run test:e2e && npm run test:axe",
    "postinstall": "prisma generate",
    "db:migrate": "node scripts/prisma-guard.mjs migrate dev && prisma migrate dev",
    "db:migrate:name": "node scripts/prisma-guard.mjs migrate dev && prisma migrate dev --name",
    "db:push": "node scripts/prisma-guard.mjs db push && prisma db push",
    "db:reset": "node scripts/prisma-guard.mjs migrate reset && prisma migrate reset",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:status": "prisma migrate status",
    "db:seed": "node scripts/prisma-guard.mjs db seed && tsx prisma/seed-superadmin.ts",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed-superadmin.ts",
    "prepare": "husky install",
    "release": "standard-version && git push --follow-tags origin main"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1025.0",
    "@elevenlabs/elevenlabs-js": "^2.40.0",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@google/generative-ai": "^0.24.1",
    "@huggingface/transformers": "^3.8.1",
    "@prisma/client": "^6.19.2",
    "@sentry/nextjs": "^9.9.0",
    "@swc/helpers": "^0.5.19",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/nodemailer": "^7.0.11",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.1",
    "dotenv": "^17.3.1",
    "eslint-config-next": "^16.2.1",
    "framer-motion": "^12.38.0",
    "glob": "^10.3.10",
    "jose": "^6.2.2",
    "next": "^15.2.4",
    "next-intl": "^4.8.3",
    "nodemailer": "^8.0.4",
    "pptxgenjs": "^4.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "redis": "^5.11.0",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/compat": "^2.0.3",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "husky": "^9.0.0",
    "jest": "^30.3.0",
    "lint-staged": "^15.0.0",
    "msw": "^2.12.14",
    "next-seo": "^6.5.0",
    "next-sitemap": "^4.0.0",
    "prisma": "^6.6.0",
    "prom-client": "^15.1.3",
    "standard-version": "^9.5.0",
    "supertest": "^7.2.2",
    "swagger-ui-express": "^5.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.8.0",
    "vitest": "^4.1.1"
  }
}
