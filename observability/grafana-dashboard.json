{
  "_comment": "Grafana dashboard for AIM Platform — import via Grafana UI (Dashboards > Import > Upload JSON)",

  "title": "AIM Platform – Observability",
  "uid": "aim-platform-main",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },

  "panels": [
    {
      "id": 1,
      "title": "Auth – Logins (Success vs Failure)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(aim_auth_success_total[5m])",
          "legendFormat": "Success ({{role}})"
        },
        {
          "expr": "rate(aim_auth_failure_total[5m])",
          "legendFormat": "Failure ({{reason}})"
        }
      ]
    },
    {
      "id": 2,
      "title": "Notification Jobs – Completed vs Failed",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(aim_notification_jobs_total{status=\"completed\"}[5m])",
          "legendFormat": "Completed ({{type}})"
        },
        {
          "expr": "rate(aim_notification_jobs_total{status=\"failed\"}[5m])",
          "legendFormat": "Failed ({{type}})"
        }
      ]
    },
    {
      "id": 3,
      "title": "Request Latency p95 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(aim_request_duration_ms_bucket[5m]))",
          "legendFormat": "p95 {{method}} {{path}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "CSRF Rejections / min",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(aim_csrf_rejected_total[1m]) * 60",
          "legendFormat": "CSRF Rejections/min"
        }
      ]
    },
    {
      "id": 5,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[1m]) * 100",
          "legendFormat": "CPU %"
        }
      ]
    },
    {
      "id": 6,
      "title": "Memory Usage (MB)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "RSS (MB)"
        }
      ]
    }
  ]
}
