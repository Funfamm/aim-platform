generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String                      @id @default(cuid())
  name                   String
  email                  String                      @unique
  passwordHash           String?
  googleId               String?                     @unique
  appleId                String?                     @unique
  avatar                 String?
  bannerUrl              String?
  role                   String                      @default("member")
  tokenVersion           Int                         @default(0)
  knownDevices           String?
  lastLoginAt            DateTime?
  emailVerified          Boolean                     @default(false)
  verificationCode       String?
  verificationExpiry     DateTime?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  trainingXp             Int                         @default(0)
  trainingStreak         Int                         @default(0)
  lastTrainingAt         DateTime?
  mfaEnabled             Boolean                     @default(false)
  failedLoginAttempts    Int                         @default(0)
  lockedUntil            DateTime?                   // auto-clears after TTL
  suspended              Boolean                     @default(false)  // manual admin ban
  mfaTempCode            String?
  mfaExpiresAt           DateTime?
  preferredLanguage      String                      @default("en")
  receiveLocalizedEmails Boolean                     @default(true)
  accentColor            String                      @default("gold")
  themeMode              String                      @default("dark")
  mediaProfile           Json?                       // { front_headshot, side_profile, full_body, expression, optional_1, optional_2, voiceRecording }
  applications           Application[]
  donations              Donation[]
  enrollments            Enrollment[]
  lessonProgress         LessonProgress[]
  passwordHistory        PasswordHistory[]
  ownedProjects          Project[]
  quizAttempts           QuizAttempt[]
  reviewActivities       ReviewActivity[]
  trainingBadges         TrainingBadge[]
  notifications              UserNotification[]
  notificationPreference     UserNotificationPreference?
  scriptCallNotifications    ScriptCallNotify[]
  watchHistory               WatchHistory[]
  watchlist                  Watchlist[]

  @@index([role])
  @@index([createdAt])
}

model Project {
  id           String         @id @default(cuid())
  title        String
  slug         String         @unique
  tagline      String         @default("")
  description  String
  status       String         @default("upcoming")
  projectType  String         @default("movie")
  coverImage   String?
  trailerUrl   String?
  filmUrl      String?
  genre        String?
  year         String?
  duration     String?
  gallery      String?
  translations String?
  credits      String?
  sponsorData  String?        // JSON: { name, logoUrl?, description? } — per-project sponsor for publish emails
  featured     Boolean        @default(false)
  published    Boolean        @default(false)  // visibility gate — only published projects appear on public pages
  sortOrder    Int            @default(0)
  viewCount    Int            @default(0)  // cached counter — incremented by /api/projects/view
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  country      String?
  ownerId      String?
  castingCalls CastingCall[]
  cast         FilmCast[]
  donations    Donation[]
  episodes     Episode[]
  subtitles    FilmSubtitle[]
  audioTracks  AudioTrack[]   // Phase 2: dubbed audio tracks
  owner        User?          @relation(fields: [ownerId], references: [id])
  scriptCalls  ScriptCall[]
  watchHistory WatchHistory[]
  watchlist    Watchlist[]
  liveEvents   LiveEvent[]
  views        ProjectView[]

  @@index([title, tagline])
  @@index([viewCount])           // trending sort
  @@index([featured, sortOrder]) // featured row
  @@index([createdAt])           // new releases sort
  @@index([genre, viewCount])    // genre rows sorted by popularity
}

// Phase 2 — Dubbed audio track per language per project/episode
model AudioTrack {
  id          String   @id @default(cuid())
  projectId   String
  episodeId   String?  // null = applies to the full film
  language    String   // ISO 639-1 e.g. "es"
  label       String   // Display label e.g. "Español (Doblaje)"
  audioUrl    String   // R2 object URL
  isPrimary   Boolean  @default(false)  // true = original/source audio
  status      String   @default("ready") // ready | processing | failed
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, episodeId, language])
  @@index([projectId])
}

model FilmCast {
  id              String   @id @default(cuid())
  projectId       String
  name            String
  jobTitle        String   // Actor, Director, Producer, etc.
  character       String?  // Character name in the film
  bio             String?  @db.Text
  photoUrl        String?
  instagramUrl    String?
  bioTranslations String?  @db.Text // JSON: Record<lang, {bio:string,character:string}>
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
}

// ── Project analytics events — powers trending, recommendations, watch time ──
model ProjectView {
  id         String   @id @default(cuid())
  projectId  String
  userId     String?  // null for anonymous visitors
  source     String   @default("browse") // browse | search | recommendation | hover | share
  locale     String   @default("en")
  durationMs Int?     // how long they stayed (set on page leave)
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
  @@index([projectId, createdAt]) // for 30-day trending window queries
}

model WatchHistory {
  id           String   @id @default(cuid())
  userId       String
  projectId    String
  watchedAt    DateTime @default(now())
  progress     Float    @default(0)
  subtitleLang String?  // ISO 639-1 code of subtitle used, null if captions off
  audioLang    String?  // ISO 639-1 code of audio track used
  captionsOn   Boolean  @default(false)
  completePct  Float?   // 0.0–1.0 fraction of video watched at session end
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, watchedAt])
  @@index([userId, projectId]) // for fast per-project lookup
}

model Episode {
  id        String   @id @default(cuid())
  projectId String
  title     String
  number    Int
  season    Int      @default(1)
  videoUrl  String?
  duration  String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, season, number])
  @@index([projectId])
}

model FilmSubtitle {
  id               String   @id @default(cuid())
  projectId        String
  episodeId        String?
  language         String   @default("en")
  originalLanguage String   @default("en")   // source language of the video content
  segments         String   // JSON: TranscriptSegment[] (source language)
  translations     String?  // JSON: Record<lang, TranscriptSegment[]>
  status           String   @default("pending")
  translateStatus  String   @default("pending") // pending|partial|complete|failed
  langStatus       Json?    // Record<lang, 'pending'|'processing'|'completed'|'failed'|'reviewed'>
  vttPaths         Json?    // Record<lang, string> — versioned R2 object keys e.g. "subtitles/{id}/{lang}-{hash}.vtt"
  qcIssues         String?  // JSON: QCResult[] — Netflix-spec checks on English track
  generatedWith    String?  // key label used for translation e.g. "My Gemini Key 1"
  transcribedWith  String?  // ASR model used e.g. "whisper-medium"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // ┬ T4: Track-level subtitle placement — desktop (defaults for all cues) ┬
  verticalAnchor   String   @default("bottom")  // bottom|lower_third|middle|upper_third|top
  horizontalAlign  String   @default("center")  // left|center|right
  offsetYPercent   Float    @default(0)
  offsetXPercent   Float    @default(0)
  safeAreaMarginPx Int      @default(12)
  backgroundStyle  String   @default("shadow")  // none|shadow|box
  fontScale        Float    @default(1.0)
  // JSON: per-cue overrides keyed by cue index string
  cueOverrides     String   @default("{}")

  // ┬ T4-M: Independent mobile placement fields ┬
  // When useSeparateMobilePlacement=false the player falls back to desktop values.
  useSeparateMobilePlacement Boolean @default(false)
  mobileVerticalAnchor       String  @default("bottom")  // bottom|lower_third
  mobileHorizontalAlign      String  @default("center")
  mobileOffsetYPercent       Float   @default(0)
  mobileOffsetXPercent       Float   @default(0)
  mobileSafeAreaMarginPx     Int     @default(20)        // larger default for home indicator
  mobileFontScale            Float   @default(0.9)       // slightly smaller for narrow screens
  
  // ┬ T4-L: Independent mobile landscape placement fields ┬
  landscapeVerticalAnchor    String  @default("bottom")
  landscapeHorizontalAlign   String  @default("center")
  landscapeOffsetYPercent    Float   @default(0)
  landscapeOffsetXPercent    Float   @default(0)
  landscapeSafeAreaMarginPx  Int     @default(20)
  landscapeFontScale         Float   @default(0.9)


  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisions        SubtitleRevision[]
  historyClearLogs SubtitleHistoryClear[]

  @@unique([projectId, episodeId])
  @@index([projectId])
}

// ┬ T3-B: Server-side subtitle revision history ┬
model SubtitleRevision {
  id             String       @id @default(cuid())
  subtitleId     String
  savedAt        DateTime     @default(now())
  savedBy        String
  savedByEmail   String       @default("")
  changeSource   String       // manual_edit|import_srt|import_vtt|auto_generate|approve|translate|restore_revision
  segmentsSnap   String
  placementSnap  String       @default("{}")
  subtitle       FilmSubtitle @relation(fields: [subtitleId], references: [id], onDelete: Cascade)

  @@index([subtitleId, savedAt])
}

// ┬ Phase 4: Audit log for admin revision-history clear actions ┬
// Lightweight record preserved even after the SubtitleRevision rows are deleted.
model SubtitleHistoryClear {
  id              String       @id @default(cuid())
  subtitleId      String
  clearedBy       String       // userId of the admin who performed the action
  clearedByEmail  String       @default("")
  clearedAt       DateTime     @default(now())
  clearActionType String       // clear_only|archive_and_clear|reset_and_clear|delete_drafts
  reason          String?      // optional admin-supplied reason
  rowsDeleted     Int          @default(0)
  subtitle        FilmSubtitle @relation(fields: [subtitleId], references: [id], onDelete: Cascade)

  @@index([subtitleId, clearedAt])
}

model CastingCall {
  id              String        @id @default(cuid())
  projectId       String
  roleName        String
  roleType        String        @default("lead")
  roleDescription String
  genre           String?
  ageRange        String?
  gender          String?
  ethnicity       String?
  requirements    String
  compensation    String?
  deadline        String?
  translations    String?
  bannerUrl       String?
  maxApplications Int           @default(50)
  status          String        @default("open")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  applications    Application[]
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([roleName, roleDescription])
  @@index([status])
  @@index([projectId])
  @@index([genre])
}

model Application {
  id                     String                    @id @default(cuid())
  castingCallId          String
  userId                 String?
  fullName               String
  email                  String
  phone                  String?
  age                    Int?
  gender                 String?
  location               String?
  experience             String
  specialSkills          String?
  agencyName             String?
  headshotPath           String?
  selfTapePath           String?
  portfolioUrl           String?
  locale                 String                    @default("en")
  aiScore                Float?
  aiFitLevel             String?
  aiReport               String?
  resultVisibleAt        DateTime?
  adminNotes             String?
  statusNote             String?
  reviewedAt             DateTime?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  photoScreeningStatus   String?
  statusNoteTranslations String?
  status                 ApplicationStatus         @default(submitted)
  audioUrl               String?
  scheduledAuditAt       DateTime?                 // legacy — kept for backward compat, no longer written
  // ── AI Audit Queue fields ──
  auditState             String?                   // queued | processing | scored_hidden | scored_visible | failed
  queuedAt               DateTime?
  aiScoredAt             DateTime?
  processingAttempts     Int                       @default(0)
  lastProcessingError    String?
  adminRevealOverride    Boolean                   @default(false)
  pendingNotifyStatus    String?                   // status whose notification is scheduled — sent by cron when notifyAfter ≤ now
  notifyAfter            DateTime?                 // fire delayed status notification at or after this time
  priority               Int                       @default(0)  // higher = processed first
  castingCall            CastingCall               @relation(fields: [castingCallId], references: [id], onDelete: Cascade)
  user                   User?                     @relation(fields: [userId], references: [id])
  notifications          ApplicationNotification[]

  @@unique([castingCallId, email])
  @@index([email])
  @@index([castingCallId])
  @@index([status])
  @@index([createdAt])
  @@index([aiScore])
  @@index([scheduledAuditAt])
  @@index([auditState])
  @@index([priority, queuedAt])
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model HeroVideo {
  id        String   @id @default(cuid())
  title     String   @default("")
  url       String
  duration  Int      @default(10)
  page      String   @default("all")
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id                            String         @id @default("default")
  siteName                      String         @default("AIM Studio")
  tagline                       String         @default("AI-Powered Filmmaking")
  aboutText                     String         @default("")
  studioStory                   String         @default("")
  mission                       String         @default("")
  aboutPageData                 String?
  logoUrl                       String?
  socialLinks                   String?
  contactEmail                  String?
  contactPhone                  String?
  address                       String?
  geminiApiKey                  String?
  aiModel                       String         @default("gemini-2.5-flash")
  aiCustomPrompt                String?
  aiAutoAudit                   Boolean        @default(false)
  autoShortlistThreshold        Int            @default(75)
  autoRejectThreshold           Int            @default(25)
  pipelineAutoAdvance           Boolean        @default(true)
  notifyApplicantOnStatusChange Boolean        @default(true)
  defaultDeadlineDays           Int            @default(30)
  castingAutoClose              Boolean        @default(false)
  requireVoice                  Boolean        @default(false)
  maxPhotoUploads               Int            @default(6)
  requireLoginForFilms          Boolean        @default(true)
  allowPublicTrailers           Boolean        @default(true)
  requireLoginForCasting        Boolean        @default(false)
  requireLoginForDonate         Boolean        @default(false)
  requireLoginForSponsors       Boolean        @default(false)
  allowPublicProjectPages       Boolean        @default(true)
  donationsEnabled              Boolean        @default(true)
  donationMinAmount             Float          @default(5.0)
  notifyOnApplication           Boolean        @default(true)
  notifyOnDonation              Boolean        @default(true)
  notifyEmail                   String?
  notifyOnNewDevice             Boolean        @default(true)
  emailTemplateOverrides        String?
  scriptCallsEnabled            Boolean        @default(false)
  castingCallsEnabled           Boolean        @default(true)
  trainingEnabled               Boolean        @default(false)
  sponsorsPageEnabled           Boolean        @default(true)
  googleClientId                String?
  googleClientSecret            String?
  appleClientId                 String?
  appleTeamId                   String?
  appleKeyId                    String?
  applePrivateKey               String?
  smtpHost                      String?
  smtpPort                      Int            @default(587)
  smtpUser                      String?
  smtpPass                      String?
  smtpFromName                  String?
  smtpFromEmail                 String?
  smtpSecure                    Boolean        @default(false)
  emailsEnabled                 Boolean        @default(false)
  searchBetaEnabled             Boolean        @default(false)
  emailTransport                EmailTransport @default(graph)
  audioUploadEnabled            Boolean        @default(true)
  notifyOnNewRole               Boolean        @default(true)
  notifyOnAnnouncement          Boolean        @default(true)
  notifyOnContentPublish        Boolean        @default(true)
  emailReplyTo                  String?
  resultRevealDelayHours        Int            @default(6)
  auditDelayHours               Int            @default(2)  // hours after submission to run auto-audit (legacy)
  auditQueueBatchSize           Int            @default(10) // max apps scored per cron run
}

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserNotificationPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  newRole        Boolean  @default(true)
  announcement   Boolean  @default(true)
  contentPublish Boolean  @default(false)
  statusChange   Boolean  @default(true)
  email          Boolean  @default(true)
  inApp          Boolean  @default(true)
  sms            Boolean  @default(false)
  updatedAt      DateTime @updatedAt
  phoneNumber    String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PreferenceAudit {
  id            String   @id @default(cuid())
  userId        String
  changedFields Json
  timestamp     DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
}

model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  eventId   String?  @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model SearchAnalytics {
  id           String   @id @default(cuid())
  userId       String?
  query        String
  resultsCount Int
  device       String   @default("desktop")
  timestamp    DateTime @default(now())
}

model ApplicationNotification {
  id                String      @id @default(cuid())
  applicationId     String
  type              String
  subject           String
  body              String
  recipientEmail    String
  status            String      @default("sent")
  notifiedForStatus String?     // dedup key — which status triggered this notification
  createdAt         DateTime    @default(now())
  application       Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, notifiedForStatus, status])
}

model Subscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  subscribedAt DateTime @default(now())
  active       Boolean  @default(true)
}

model EmailLog {
  id        String   @id @default(cuid())
  to        String
  subject   String
  type      String   @default("general")
  transport String   @default("unknown")
  success   Boolean
  error     String?
  sentAt    DateTime @default(now())

  @@index([sentAt])
  @@index([success])
  @@index([type])
}

model Donation {
  id        String   @id @default(cuid())
  userId    String?
  projectId String?
  name      String
  email     String
  amount    Float
  message   String?
  anonymous Boolean  @default(false)
  method    String   @default("card")
  status    String   @default("completed")
  createdAt DateTime @default(now())
  project   Project? @relation(fields: [projectId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@index([projectId])
}

model Sponsor {
  id                  String    @id @default(cuid())
  name                String
  description         String?
  descriptionI18n     Json?
  logoUrl             String?
  bannerUrl           String?
  website             String?
  tier                String    @default("bronze")
  active              Boolean   @default(true)
  featured            Boolean   @default(false)
  displayOn           String    @default("sponsors")
  contactEmail        String?
  startDate           DateTime?
  endDate             DateTime?
  sortOrder           Int       @default(0)
  bannerDurationHours Int       @default(24)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([name])
  @@index([active])
  @@index([tier])
  @@index([displayOn])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PageMedia {
  id        String   @id @default(cuid())
  page      String
  type      String   @default("background")
  url       String
  title     String   @default("")
  sortOrder Int      @default(0)
  duration  Int      @default(10)
  active    Boolean  @default(true)
  target    String   @default("all")  // "all" | "desktop" | "mobile"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([page, type])
  @@index([active])
}

model ScriptCall {
  id                   String             @id @default(cuid())
  title                String
  description          String
  genre                String?
  toneKeywords         String?
  targetLength         String?
  projectId            String?
  status               String             @default("draft")
  isPublic             Boolean            @default(false)
  deadline             String?
  maxSubmissions       Int                @default(100)
  contentTranslations  String?            @db.Text
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  project              Project?           @relation(fields: [projectId], references: [id])
  submissions          ScriptSubmission[]
  notifications        ScriptCallNotify[]

  @@index([title])
}

model ScriptCallNotify {
  id           String    @id @default(cuid())
  scriptCallId String
  userId       String
  createdAt    DateTime  @default(now())
  scriptCall   ScriptCall @relation(fields: [scriptCallId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scriptCallId, userId])
  @@index([userId])
}

model ScriptSubmission {
  id                 String          @id @default(cuid())
  scriptCallId       String
  authorName         String
  authorEmail        String
  authorBio          String?
  title              String
  logline            String
  synopsis           String
  scriptText         String?
  scriptFilePath     String?
  genre              String?
  estimatedDuration  String?
  status             String          @default("submitted")
  lastNotifiedStatus String?         // dedup key — last status a notification was sent for
  createdAt          DateTime        @default(now())
  analysis           ScriptAnalysis?
  scriptCall         ScriptCall      @relation(fields: [scriptCallId], references: [id], onDelete: Cascade)

  @@index([scriptCallId])
}

model ScriptAnalysis {
  id                   String           @id @default(cuid())
  submissionId         String           @unique
  originalityScore     Float            @default(0)
  structureScore       Float            @default(0)
  dialogueScore        Float            @default(0)
  visualPotentialScore Float            @default(0)
  themeAlignmentScore  Float            @default(0)
  feasibilityScore     Float            @default(0)
  overallScore         Float            @default(0)
  strengths            String?
  concerns             String?
  recommendation       String?
  rawReport            String?
  analyzedAt           DateTime         @default(now())
  submission           ScriptSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  userId    String?
  userAgent String?
  referrer  String?
  device    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([userId])
  @@index([device])
}

model FilmView {
  id            String   @id @default(cuid())
  projectId     String
  userId        String?
  watchDuration Int      @default(0)
  completed     Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
}

model ApiKey {
  id              String       @id @default(cuid())
  label           String       @default("API Key")
  provider        String       @default("gemini")
  key             String
  isActive        Boolean      @default(true)
  assignedAgent   String       @default("all")
  usageCount      Int          @default(0)
  lastUsed        DateTime?
  lastError       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  cooledDownUntil DateTime?
  quota           ApiKeyQuota?
}

model ApiKeyQuota {
  id             String    @id @default(cuid())
  apiKeyId       String    @unique
  windowMaxCalls Int       @default(50)
  usedInWindow   Int       @default(0)
  windowResetAt  DateTime
  cooldownUntil  DateTime?
  apiKey         ApiKey    @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
}

model Course {
  id            String         @id @default(cuid())
  title         String
  slug          String         @unique
  description   String
  thumbnail     String?
  category      String         @default("acting")
  level         String         @default("beginner")
  translations  String?
  sourceContent String?
  published     Boolean        @default(false)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  duration      String?
  modules       CourseModule[]
  enrollments   Enrollment[]

  @@index([published])
  @@index([category])
}

model CourseModule {
  id           String             @id @default(cuid())
  courseId     String
  title        String
  description  String?
  translations String?
  sortOrder    Int                @default(0)
  course       Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  materials    LearningMaterial[]
  lessons      Lesson[]
  quiz         Quiz?

  @@index([courseId])
}

model Lesson {
  id                  String           @id @default(cuid())
  moduleId            String
  title               String
  contentType         String           @default("video")
  contentUrl          String?
  uploadPath          String?
  description         String?
  duration            Int?
  translations        String?
  sortOrder           Int              @default(0)
  completionThreshold Float            @default(0.95)
  minTimeSeconds      Int?
  module              CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress            LessonProgress[]
  transcript          Transcript?

  @@index([moduleId])
}

model Transcript {
  id           String   @id @default(cuid())
  lessonId     String   @unique
  language     String   @default("en")
  segments     String
  translations String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id              String    @id @default(cuid())
  userId          String
  courseId        String
  completedAt     DateTime?
  certificateId   String?
  currentModuleId String?
  currentLessonId String?
  mode            String    @default("learning")
  enrolledAt      DateTime  @default(now())
  course          Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([userId])
}

model LessonProgress {
  id             String    @id @default(cuid())
  userId         String
  lessonId       String
  completed      Boolean   @default(false)
  completedAt    DateTime?
  timeSpent      Int       @default(0)
  videoTimestamp Float?
  pdfPage        Int?
  scrollDepth    Float?
  mode           String    @default("first_time")
  updatedAt      DateTime  @updatedAt
  lesson         Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model TrainingBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeType String
  earnedAt  DateTime @default(now())
  courseId  String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeType])
  @@index([userId])
}

model Quiz {
  id           String         @id @default(cuid())
  moduleId     String         @unique
  title        String
  passMark     Int            @default(80)
  maxAttempts  Int            @default(1)
  translations String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  module       CourseModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  attempts     QuizAttempt[]
  questions    QuizQuestion[]
}

model EmailAuditLog {
  id           String         @id @default(cuid())
  createdAt    DateTime       @default(now())
  userId       String?
  transport    EmailTransport
  to           String
  subject      String
  status       String
  errorMessage String?
}

model QuizQuestion {
  id            String  @id @default(cuid())
  quizId        String
  questionText  String
  questionType  String  @default("single")
  options       String
  correctAnswer String
  explanation   String?
  sourceRef     String?
  translations  String?
  sortOrder     Int     @default(0)
  quiz          Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model QuizAttempt {
  id            String   @id @default(cuid())
  userId        String
  quizId        String
  score         Int
  passed        Boolean
  answers       String
  attemptNumber Int      @default(1)
  createdAt     DateTime @default(now())
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

