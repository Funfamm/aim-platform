model LearningMaterial {
  id        String       @id @default(cuid())
  moduleId  String
  fileName  String
  fileType  String
  filePath  String
  fileSize  Int?
  metadata  String?
  createdAt DateTime     @default(now())
  module    CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

