enum EmailTransport {
  graph
  smtp
}

enum ApplicationStatus {
  submitted
  under_review
  reviewed
  shortlisted
  contacted
  audition
  callback
  final_review
  selected
  not_selected
  rejected
  withdrawn
  pending
  approved
}

// ─── Admin Audit Log ──────────────────────────────────────────────────────────
// Persists every privileged admin action for accountability & incident review.
// Separate from the existing logger/console output so the UI can query it.
model AdminAuditLog {
  id            String   @id @default(cuid())
  actor         String   // userId of the admin
  action        String   // AuditAction enum value
  targetSummary String   // human-readable summary e.g. "47 applications (rejected)"
  details       Json?    // arbitrary metadata
  createdAt     DateTime @default(now())

  @@index([action])
  @@index([actor])
  @@index([createdAt])
}

// ─── LiveKit Live Events & Watch Parties ──────────────────────────────────────
// Backs every realtime room: live auditions, Q&A, premieres, and watch parties.
// Watch Party events use Redis Pub/Sub + SSE for sync — LiveKit is NOT used for WP.
model LiveEvent {
  id             String    @id @default(cuid())
  title          String
  roomName       String    @unique
  status         String    @default("scheduled") // scheduled | live | ended
  eventType      String    @default("general")   // general | audition | q_and_a | watch_party

  // ── Scheduling ──────────────────────────────────────────────────────────────
  scheduledAt    DateTime? // when the event is planned to start (drives invite expiry)
  startedAt      DateTime?
  endedAt        DateTime?

  // ── LiveKit event settings ───────────────────────────────────────────────────
  // permissions JSON: { camera, mic, screenShare, chat, reactions } — all booleans
  // Enforced at token-mint time and via UpdateParticipant for live changes.
  permissions    Json?     // LiveKit events only
  captionsActive Boolean   @default(false) // true while caption worker is connected
  recordingUrl   String?   // set by egress worker after recording completes
  egressId       String?   // LiveKit egress ID while a recording is in progress

  // ── Watch Party settings ─────────────────────────────────────────────────────
  // projectId holds the linked film; episodeId optionally pins to a specific episode.
  // The actual media URL is resolved server-side from Project.filmUrl / Episode.videoUrl
  // and delivered as a short-lived presigned R2 URL — never stored on this model.
  episodeId      String?   // optional — pins to a specific Episode within the project
  lobbyEnabled   Boolean   @default(true)  // show waiting room before host starts
  replayEnabled  Boolean   @default(false) // allow re-watching after event ends

  // Durable playback milestones — NOT the live sync loop (Redis owns live state)
  playbackStartedAt DateTime?
  lastCheckpointSec Float?    // written at: play, end, and seeks > 10 min

  // ── Relations ────────────────────────────────────────────────────────────────
  hostUserId     String
  projectId      String?
  castingCallId  String?   // for audition rooms — ties room to a specific CastingCall
  project        Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  invites        EventInvite[]
  messages       WatchPartyMessage[]
  reactions      WatchPartyReaction[]
  analytics      LiveEventAnalyticEvent[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([hostUserId])
  @@index([projectId])
  @@index([scheduledAt])
  @@index([eventType, status])
}

// ── Admin-curated movie collections for homepage/works page rows ──

model MovieRoll {
  id           String             @id @default(cuid())
  title        String             // Display name, e.g. "Award Winners"
  titleI18n    String?            // JSON i18n: { "fr": "Primés", "es": "Premiados", ... }
  icon         String             @default("🎬") // Emoji or symbol shown beside the title
  slug         String             @unique        // URL-safe identifier
  displayOn    String             @default("both") // "homepage" | "works" | "both"
  visible      Boolean            @default(true)
  sortOrder    Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  projects     MovieRollProject[]

  @@index([visible, sortOrder])
  @@index([displayOn])
}

model MovieRollProject {
  id         String    @id @default(cuid())
  rollId     String
  projectId  String
  sortOrder  Int       @default(0)
  roll       MovieRoll @relation(fields: [rollId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@unique([rollId, projectId])
  @@index([rollId, sortOrder])
}

// ── Server-side subtitle generation job tracking ──────────────────────────────
// Created when an admin clicks "Generate Subtitles (Server)".
// Tracks the full lifecycle: queued → processing → ready | failed
//
// State machine:
//   queued      – job row created, not yet picked up by the worker
//   processing  – worker acknowledged the job and is transcribing
//   ready       – worker returned VTT/SRT URLs, subtitle saved
//   failed      – worker reported an error or timed out (>2 h, caught by cron)
//
// One active job per (projectId, episodeId) is enforced in the generate route.
model SubtitleJob {
  id             String    @id @default(cuid())
  projectId      String
  episodeId      String?                              // null = whole film, non-null = episode
  status         String    @default("queued")         // queued | processing | ready | failed
  sourceVideoUrl String                               // URL passed to the worker
  workerRunId    String?                              // opaque ID returned by the worker
  vttUrl         String?                              // public R2 URL of the .vtt file
  srtUrl         String?                              // public R2 URL of the .srt file
  errorMessage   String?
  retriedJobId   String?                              // previous job this retried
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([projectId, episodeId, status])             // fast "is a job running?" lookup
  @@index([status, createdAt])                        // cron: find stuck jobs
  @@index([projectId])
}

// --- Watch Party & Event Invite Infrastructure ---

// First-class invite/access model.
// Token: 256-bit crypto.randomBytes(32) hex. DB stores SHA-256 hash only.
// Raw token is emailed to recipient in the invite URL -- never persisted server-side.
model EventInvite {
  id              String    @id @default(cuid())
  eventId         String
  tokenHash       String    @unique
  recipientUserId String?
  recipientEmail  String?
  role            String    @default("viewer")
  status          String    @default("pending")
  locale          String    @default("en")
  sentAt          DateTime  @default(now())
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  revokedByUserId String?
  event           LiveEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([eventId])
  @@index([recipientUserId])
  @@index([recipientEmail])
}

// Watch-party chat messages. Dedicated table -- NOT a JSON blob on LiveEvent.
model WatchPartyMessage {
  id               String    @id @default(cuid())
  eventId          String
  userId           String?
  senderName       String
  content          String
  hidden           Boolean   @default(false)
  hiddenAt         DateTime?
  hiddenByUserId   String?
  moderationReason String?
  createdAt        DateTime  @default(now())
  event            LiveEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
  @@index([eventId, hidden])
}

// Watch-party emoji reactions.
model WatchPartyReaction {
  id               String    @id @default(cuid())
  eventId          String
  userId           String?
  emoji            String
  hidden           Boolean   @default(false)
  hiddenAt         DateTime?
  hiddenByUserId   String?
  moderationReason String?
  createdAt        DateTime  @default(now())
  event            LiveEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
}

// Structured analytics log for all live event and watch-party milestones.
// joined_room fires on actual LiveKit connection -- NOT token issuance.
model LiveEventAnalyticEvent {
  id        String    @id @default(cuid())
  eventId   String
  userId    String?
  name      String
  metadata  Json?
  createdAt DateTime  @default(now())
  event     LiveEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, name])
  @@index([eventId, createdAt])
  @@index([userId])
}