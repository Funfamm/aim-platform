generator client {
  provider = "prisma-client-js"
}

datasource db {
  // PRODUCTION: Neon PostgreSQL via pooler
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum EmailTransport {
  graph
  smtp
}

model User {
  id                 String            @id @default(cuid())
  name               String
  email              String            @unique
  passwordHash       String? // null for Google/Apple-only users
  googleId           String?           @unique
  appleId            String?           @unique
  avatar             String?
  bannerUrl          String? // Custom dashboard banner image
  role               String            @default("member") // member | admin | superadmin
  tokenVersion       Int               @default(0) // incremented on credential changes
  knownDevices       String? // JSON array of hashed device fingerprints
  lastLoginAt        DateTime?
  // Email verification
  emailVerified      Boolean           @default(false)
  verificationCode   String? // 6-digit OTP
  verificationExpiry DateTime? // Code expires after 15 minutes
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  applications       Application[]
  donations          Donation[]
  watchlist          Watchlist[]
  watchHistory       WatchHistory[]
  // Training
  enrollments        Enrollment[]
  lessonProgress     LessonProgress[]
  trainingBadges     TrainingBadge[]
  quizAttempts       QuizAttempt[]
  reviewActivities   ReviewActivity[]
  trainingXp         Int               @default(0)
  trainingStreak     Int               @default(0)
  lastTrainingAt     DateTime?
  // Security
  passwordHistory    PasswordHistory[]
  // Projects owned
  ownedProjects      Project[]

  @@index([role])
  @@index([createdAt])
}

model Project {
  id           String         @id @default(cuid())
  title        String
  slug         String         @unique
  tagline      String         @default("")
  description  String
  status       String         @default("upcoming") // upcoming | in-production | completed
  projectType  String         @default("movie") // movie | series
  coverImage   String?
  trailerUrl   String?
  filmUrl      String? // Full film — member-only access
  country      String? // ISO country code for reach metric
  ownerId      String? // reference to User who created the project
  owner        User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  genre        String?
  year         String?
  duration     String?
  gallery      String? // JSON array of image paths
  translations String? // JSON: { "zh": { "title": "...", "tagline": "...", ... }, ... }
  credits      String? // JSON: { director, producer, cast, etc. }
  featured     Boolean        @default(false)
  sortOrder    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  castingCalls CastingCall[]
  donations    Donation[]
  episodes     Episode[]
  scriptCalls  ScriptCall[]
  watchlist    Watchlist[]
  watchHistory WatchHistory[]
  subtitles    FilmSubtitle[]

  // Index for fast title/tagline search
  @@index([title, tagline])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([userId])
}

model WatchHistory {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  watchedAt DateTime @default(now())
  progress  Float    @default(0) // 0-100 percentage watched

  @@index([userId, watchedAt])
}

model Episode {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  number    Int // Episode number
  season    Int      @default(1)
  videoUrl  String? // Episode video URL
  duration  String?
  createdAt DateTime @default(now())

  @@unique([projectId, season, number])
  @@index([projectId])
}

model FilmSubtitle {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  episodeId    String? // null for movies, set for series episodes
  language     String   @default("en") // original transcription language
  segments     String // JSON: [{ start, end, text }]
  translations String? // JSON: { "es": [{ start, end, text }], "fr": [...], ... }
  status       String   @default("pending") // pending | transcribing | translating | completed | error
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([projectId, episodeId])
  @@index([projectId])
}

model CastingCall {
  id              String        @id @default(cuid())
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roleName        String
  roleType        String        @default("lead") // lead | supporting | extra | voice
  roleDescription String
  ageRange        String?
  gender          String?
  ethnicity       String?
  requirements    String // Detailed requirements for the role
  compensation    String?
  deadline        String?
  translations    String? // JSON: { "zh": { "roleName": "...", "roleDescription": "..." }, ... }
  maxApplications Int           @default(50) // Auto-close after this many applications
  status          String        @default("open") // open | closed | filled
  applications    Application[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Index for role name/description search
  @@index([roleName, roleDescription])
  @@index([status])
  @@index([projectId])
}

model Application {
  id                     String                    @id @default(cuid())
  castingCallId          String
  castingCall            CastingCall               @relation(fields: [castingCallId], references: [id], onDelete: Cascade)
  userId                 String? // linked when applicant is logged in
  user                   User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  fullName               String
  email                  String
  phone                  String?
  age                    Int?
  gender                 String?
  location               String?
  experience             String // Resume/bio text
  audioUrl               String? // URL of uploaded audio recording
  specialSkills          String?
  agencyName             String?
  headshotPath           String?
  selfTapePath           String?
  portfolioUrl           String?
  locale                 String                    @default("en") // User's locale at time of application
  status                 ApplicationStatus         @default(submitted)
  aiScore                Float?
  aiFitLevel             String? // STRONG_FIT | GOOD_FIT | MODERATE | WEAK_FIT
  aiReport               String? // JSON: { overallScore, roleFitScore, strengths, concerns, recommendation, notes }
  resultVisibleAt        DateTime? // When AI result becomes visible to applicant (delayed reveal)
  adminNotes             String?
  statusNote             String? // AI-generated note shown to the applicant explaining the decision
  statusNoteTranslations String? // JSON: { "ar": "...", "fr": "..." } ??? cached translations of statusNote
  photoScreeningStatus   String? // 'skipped' | 'completed'
  reviewedAt             DateTime?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  notifications          ApplicationNotification[]

  @@unique([castingCallId, email]) // Prevent duplicate applications for same role
  @@index([email])
  @@index([castingCallId])
  @@index([status])
  @@index([createdAt])
  @@index([aiScore])
}

enum ApplicationStatus {
  submitted
  under_review
  reviewed
  shortlisted
  contacted
  audition
  callback
  final_review
  selected
  not_selected
  rejected
  withdrawn
  pending
  approved
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model HeroVideo {
  id        String   @id @default(cuid())
  title     String   @default("")
  url       String // path like /videos/1.mp4
  duration  Int      @default(10) // seconds to show before switching
  page      String   @default("all") // all | home | works | casting
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  // Feature flag for premium mobile search UI
  searchBetaEnabled Boolean @default(false) // toggle search UI
  id                String  @id @default("default")
  siteName          String  @default("AIM Studio")
  tagline           String  @default("AI-Powered Filmmaking")
  aboutText         String  @default("")
  studioStory       String  @default("") // Rich about page content
  mission           String  @default("")
  aboutPageData     String? // JSON: all About page section overrides
  logoUrl           String?
  socialLinks       String? // JSON: { youtube, instagram, tiktok, x, imdb }
  contactEmail      String?
  contactPhone      String?
  address           String?

  // AI Audition Config
  geminiApiKey   String?
  aiModel        String  @default("gemini-2.5-flash")
  aiCustomPrompt String? // Additional instructions appended to audit prompt
  aiAutoAudit    Boolean @default(false) // Auto-run AI audit on new applications

  // Pipeline Automation
  autoShortlistThreshold        Int     @default(75) // AI score >= this ??? auto-shortlist
  autoRejectThreshold           Int     @default(25) // AI score <= this ??? auto-reject
  pipelineAutoAdvance           Boolean @default(true) // Enable AI-driven auto-advance
  notifyApplicantOnStatusChange Boolean @default(true) // Email applicant on status change

  // Casting Defaults
  defaultDeadlineDays Int     @default(30)
  castingAutoClose    Boolean @default(false) // Auto-close casting when filled
  requireVoice        Boolean @default(false) // Require voice recording
  maxPhotoUploads     Int     @default(6)
  audioUploadEnabled  Boolean @default(true) // Enable/disable audio upload feature

  // Content Access
  requireLoginForFilms    Boolean @default(true)
  allowPublicTrailers     Boolean @default(true)
  requireLoginForCasting  Boolean @default(false) // require login to view casting listings
  requireLoginForDonate   Boolean @default(false) // require login to access donate page
  requireLoginForSponsors Boolean @default(false) // require login to view sponsor wall
  allowPublicProjectPages Boolean @default(true) // allow project detail pages without login

  // Donations
  donationsEnabled  Boolean @default(true)
  donationMinAmount Float   @default(5.0)

  // Notifications
  notifyOnApplication    Boolean @default(true)
  notifyOnDonation       Boolean @default(true)
  notifyEmail            String? // Override email for notifications
  notifyOnNewDevice      Boolean @default(true) // toggle for new device login alerts
  emailTemplateOverrides String? // JSON map of {templateKey: customHTML} for admin-edited templates

  // Section Visibility
  scriptCallsEnabled  Boolean @default(false) // master toggle for script call system
  castingCallsEnabled Boolean @default(true) // master toggle ??? hide all casting calls from platform
  trainingEnabled     Boolean @default(false) // master toggle for training hub
  sponsorsPageEnabled Boolean @default(true) // master toggle ??? show/hide public sponsors page

  // OAuth Configuration
  googleClientId     String?
  googleClientSecret String?
  appleClientId      String?
  appleTeamId        String?
  appleKeyId         String?
  applePrivateKey    String? // PEM format private key

  // Email / SMTP Configuration
  smtpHost       String?
  smtpPort       Int            @default(587)
  smtpUser       String? // SMTP login email
  smtpPass       String? // SMTP password / app password
  smtpFromName   String? // Display name e.g. "AIM Studio"
  smtpFromEmail  String? // From address e.g. aimstudio@impactaistudio.com
  smtpSecure     Boolean        @default(false) // true = SSL (465), false = STARTTLS (587)
  emailsEnabled  Boolean        @default(false) // master kill switch
  emailTransport EmailTransport @default(graph) // enum
  emailReplyTo   String? // Optional reply-to override e.g. noreply@impactaistudio.com
}

// Password history for reuse prevention

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String
  createdAt    DateTime @default(now())

  @@index([userId])
}

model SearchAnalytics {
  id           String   @id @default(cuid())
  userId       String?
  query        String
  resultsCount Int
  device       String   @default("desktop")
  timestamp    DateTime @default(now())
  // No relation to User to simplify migration
}

// Notification log for applicant communications
model ApplicationNotification {
  id             String      @id @default(cuid())
  applicationId  String
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type           String // status_change | ai_result | reminder
  subject        String
  body           String
  recipientEmail String
  status         String      @default("sent") // sent | failed
  createdAt      DateTime    @default(now())
}

model Subscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  subscribedAt DateTime @default(now())
  active       Boolean  @default(true)
}

model Donation {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  name      String
  email     String
  amount    Float
  message   String?
  anonymous Boolean  @default(false)
  method    String   @default("card") // card | paypal | other
  status    String   @default("completed") // pending | completed | failed
  createdAt DateTime @default(now())

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@index([projectId])
}

model Sponsor {
  id                  String    @id @default(cuid())
  name                String
  description         String? // About the sponsor
  logoUrl             String?
  bannerUrl           String? // Banner image for featured display
  website             String? // Clickable link for visitors
  tier                String    @default("bronze") // gold | silver | bronze | platinum
  active              Boolean   @default(true)
  featured            Boolean   @default(false) // Show prominently on homepage
  displayOn           String    @default("sponsors") // sponsors | homepage | footer | all
  contactEmail        String?
  startDate           DateTime? // Sponsorship start
  endDate             DateTime? // Sponsorship end (null = indefinite)
  sortOrder           Int       @default(0)
  bannerDurationHours Int       @default(24) // How many hours this banner displays before rotating
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Index for sponsor name search
  @@index([name])
  @@index([active])
  @@index([tier])
  @@index([displayOn])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PageMedia {
  id        String   @id @default(cuid())
  page      String // donate | subscribe | about | contact | home | works | casting | upcoming
  type      String   @default("background") // background | gallery | hero | video | hero-video
  url       String // file path like /images/uploads/xxx.png
  title     String   @default("")
  sortOrder Int      @default(0)
  duration  Int      @default(10) // seconds (used for hero-video type)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([page, type])
  @@index([active])
}

// ????????? Script Call System ?????????

model ScriptCall {
  id             String             @id @default(cuid())
  title          String
  description    String
  genre          String?
  toneKeywords   String? // comma-separated: "dark, suspenseful, poetic"
  targetLength   String? // e.g. "short film 10-15 min"
  projectId      String?
  project        Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  status         String             @default("draft") // draft | open | closed | archived
  isPublic       Boolean            @default(false) // admin controls visibility
  deadline       String?
  maxSubmissions Int                @default(100)
  submissions    ScriptSubmission[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  // Index for script title search
  @@index([title])
}

model ScriptSubmission {
  id                String          @id @default(cuid())
  scriptCallId      String
  scriptCall        ScriptCall      @relation(fields: [scriptCallId], references: [id], onDelete: Cascade)
  authorName        String
  authorEmail       String
  authorBio         String?
  title             String
  logline           String // one-line pitch
  synopsis          String // full synopsis
  scriptText        String? // pasted full script
  scriptFilePath    String? // uploaded PDF path
  genre             String?
  estimatedDuration String?
  status            String          @default("submitted") // submitted | analyzing | analyzed | shortlisted | selected | rejected
  analysis          ScriptAnalysis?
  createdAt         DateTime        @default(now())

  @@index([scriptCallId])
}

model ScriptAnalysis {
  id                   String           @id @default(cuid())
  submissionId         String           @unique
  submission           ScriptSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  originalityScore     Float            @default(0)
  structureScore       Float            @default(0)
  dialogueScore        Float            @default(0)
  visualPotentialScore Float            @default(0)
  themeAlignmentScore  Float            @default(0)
  feasibilityScore     Float            @default(0)
  overallScore         Float            @default(0)
  strengths            String?
  concerns             String?
  recommendation       String?
  rawReport            String? // full JSON from AI
  analyzedAt           DateTime         @default(now())
}

// ?????? Analytics ??????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????

model PageView {
  id        String   @id @default(cuid())
  path      String
  userId    String?
  userAgent String?
  referrer  String?
  device    String? // desktop | mobile | tablet
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([userId])
  @@index([device])
}

model FilmView {
  id            String   @id @default(cuid())
  projectId     String
  userId        String?
  watchDuration Int      @default(0) // seconds watched
  completed     Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
}

model ApiKey {
  id            String    @id @default(cuid())
  label         String    @default("API Key")
  provider      String    @default("gemini") // gemini | groq | openai
  key           String
  isActive      Boolean   @default(true)
  assignedAgent String    @default("all") // all | audition | analytics | scripts | training
  usageCount    Int       @default(0)
  lastUsed      DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ????????? Training System ?????????

model Course {
  id            String         @id @default(cuid())
  title         String
  slug          String         @unique
  description   String
  thumbnail     String?
  category      String         @default("acting") // acting | cinematography | directing | writing | ai | production | vfx
  level         String         @default("beginner") // beginner | intermediate | advanced | all
  translations  String? // JSON: { "zh": { "title": "...", "description": "..." }, ... }
  sourceContent String? // Raw course material pasted by admin for AI generation
  published     Boolean        @default(false)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  modules       CourseModule[]
  enrollments   Enrollment[]

  @@index([published])
  @@index([category])
}

model CourseModule {
  id           String             @id @default(cuid())
  courseId     String
  course       Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  translations String?
  sortOrder    Int                @default(0)
  lessons      Lesson[]
  quiz         Quiz?
  materials    LearningMaterial[]

  @@index([courseId])
}

model Lesson {
  id                  String           @id @default(cuid())
  moduleId            String
  module              CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title               String
  contentType         String           @default("video") // video | document | link | quiz | audio | slides
  contentUrl          String? // external video URL or link
  uploadPath          String? // uploaded file path
  description         String?
  duration            Int? // minutes
  translations        String?
  sortOrder           Int              @default(0)
  completionThreshold Float            @default(0.95) // 0.95 for video = 95% watched
  minTimeSeconds      Int? // minimum time to spend on reading/content
  progress            LessonProgress[]
  transcript          Transcript?

  @@index([moduleId])
}

model Transcript {
  id           String   @id @default(cuid())
  lessonId     String   @unique
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  language     String   @default("en")
  segments     String // JSON: [{ start, end, text, words: [{ word, start, end }] }]
  translations String? // JSON: { "zh": [{ start, end, text }], "es": [...] }
  status       String   @default("pending") // pending | processing | completed | error
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Enrollment {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completedAt     DateTime?
  certificateId   String?
  currentModuleId String? // tracks where the student is
  currentLessonId String? // tracks the current lesson
  mode            String    @default("learning") // learning | review
  enrolledAt      DateTime  @default(now())

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([userId])
}

model LessonProgress {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId       String
  lesson         Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed      Boolean   @default(false)
  completedAt    DateTime?
  timeSpent      Int       @default(0) // seconds
  videoTimestamp Float? // seconds into the video
  pdfPage        Int? // current PDF page
  scrollDepth    Float? // 0.0 - 1.0 scroll percentage
  mode           String    @default("first_time") // first_time | review
  updatedAt      DateTime  @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
}

model TrainingBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeType String // first_lesson | first_course | streak_7 | streak_30 | completionist | top_performer
  earnedAt  DateTime @default(now())
  courseId  String?

  @@unique([userId, badgeType])
  @@index([userId])
}

// ????????? Quiz Engine ?????????

model Quiz {
  id           String         @id @default(cuid())
  moduleId     String         @unique // one quiz per module
  module       CourseModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title        String
  passMark     Int            @default(80) // percentage
  maxAttempts  Int            @default(1) // per cycle
  translations String?
  questions    QuizQuestion[]
  attempts     QuizAttempt[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model EmailAuditLog {
  id           String         @id @default(cuid())
  createdAt    DateTime       @default(now())
  userId       String? // admin who triggered the email
  transport    EmailTransport
  to           String
  subject      String
  status       String // success, failed, retry
  errorMessage String? // populated on failure
}

model QuizQuestion {
  id            String  @id @default(cuid())
  quizId        String
  quiz          Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionText  String
  questionType  String  @default("single") // single | multiple | truefalse
  options       String // JSON: [{ "id": "a", "text": "..." }, ...]
  correctAnswer String // JSON: "a" or ["a","c"] for multiple
  explanation   String? // admin-only: why this is correct
  sourceRef     String? // JSON: { "lessonId": "...", "timestamp": 120, "section": "..." }
  translations  String?
  sortOrder     Int     @default(0)

  @@index([quizId])
}

model QuizAttempt {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score         Int // percentage
  passed        Boolean
  answers       String // JSON: { "questionId": "selectedAnswer", ... }
  attemptNumber Int      @default(1)
  createdAt     DateTime @default(now())

  @@index([userId, quizId])
  @@index([quizId])
}

// ????????? Learning Materials ?????????

model LearningMaterial {
  id        String       @id @default(cuid())
  moduleId  String
  module    CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  fileName  String
  fileType  String // video | pdf | docx | pptx | audio | image | url
  filePath  String
  fileSize  Int? // bytes
  metadata  String? // JSON: extracted metadata (duration, pages, etc.)
  createdAt DateTime     @default(now())

  @@index([moduleId])
}

// ????????? Review Activity ?????????

model ReviewActivity {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId     String
  lessonId     String? // optional: specific lesson reviewed
  activityType String // lesson_viewed | video_watched | reading_reviewed | quiz_reviewed
  duration     Int      @default(0) // seconds spent
  metadata     String? // JSON: { "timestamp": 120, "scrollDepth": 0.8 }
  createdAt    DateTime @default(now())

  @@index([userId, moduleId])
  @@index([moduleId])
}
